{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "worker values",
  "type": "object",
  "required": ["image"],
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 0 },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "partOf": { "type": "string" },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "commonLabels": { "type": "object" },
    "commonAnnotations": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "command": { "type": "array" },
    "args": { "type": "array" },
    "env": { "type": "object" },
    "envFrom": { "type": "array" },
    "resources": { "type": "object" },
    "keda": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicaCount": { "type": "integer", "minimum": 0 },
        "maxReplicaCount": { "type": "integer", "minimum": 1 },
        "cooldownPeriod": { "type": "integer", "minimum": 0 },
        "pollingInterval": { "type": "integer", "minimum": 1 },
        "triggers": { "type": "array", "minItems": 1 }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "metricName": { "type": "string" },
        "targetAverageValue": { "type": "string" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "probes": { "type": "object" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "volumes": { "type": "array" },
    "volumeMounts": { "type": "array" },
    "nodeSelector": { "type": "object" },
    "affinity": { "type": "object" },
    "tolerations": { "type": "array" },
    "topologySpreadConstraints": { "type": "array" }
  }
}
